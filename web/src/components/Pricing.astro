---
const appStoreAvailable = import.meta.env.PUBLIC_APP_STORE_AVAILABLE === 'true'

const perks = [
  'Unlimited dictation',
  '7 languages',
  'Free updates',
  'Privacy-first',
]
---

<section id="pricing" class="py-40 px-6 scroll-mt-20" x-data="{ notifyOpen: false }">
  <div class="reveal max-w-2xl mx-auto text-center">
    {appStoreAvailable ? (
      <p class="text-lg text-muted font-light">One app. One price. No subscriptions.</p>

      <div class="text-[clamp(72px,14vw,140px)] font-black tracking-[-0.04em] leading-none text-text mt-6">
        $4.99
      </div>

      <div class="mt-10 flex flex-wrap justify-center gap-x-5 gap-y-1.5 text-[15px] text-muted">
        {perks.map((perk, i) => (
          <>
            {i > 0 && <span class="text-faint" aria-hidden="true">&middot;</span>}
            <span>{perk}</span>
          </>
        ))}
      </div>

      <a
        href="#"
        class="mt-12 inline-flex items-center gap-2 bg-accent text-white px-10 py-3.5 rounded-pill text-base font-semibold hover:bg-accent/85 hover:shadow-[0_4px_24px_rgba(0,0,0,0.15)] transition-[background-color,box-shadow,transform] duration-200 active:scale-[0.97] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="opacity-80">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Buy on Mac App Store
      </a>
    ) : (
      <p class="text-lg text-muted font-light">Open source. No subscriptions.</p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Build it yourself — free -->
        <div class="border border-black/[0.08] rounded-[20px] px-8 pt-10 pb-8 flex flex-col items-center">
          <p class="text-xs font-semibold uppercase tracking-widest text-muted">Open Source</p>
          <div class="text-[clamp(48px,10vw,72px)] font-black tracking-[-0.04em] leading-none text-text mt-3">
            Free
          </div>
          <p class="text-sm text-muted mt-3">Download or build it yourself.</p>
          <div class="mt-auto pt-8 w-full flex flex-col items-center">
            <a
              href="https://github.com/robalaban/opendictation"
              rel="noopener noreferrer"
              class="w-full max-w-[240px] h-12 inline-flex items-center justify-center gap-2 bg-accent text-white rounded-pill text-sm font-semibold hover:bg-accent/85 hover:shadow-[0_4px_24px_rgba(0,0,0,0.15)] transition-[background-color,box-shadow,transform] duration-200 active:scale-[0.97] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
            >
              <svg class="w-[18px] h-[18px] opacity-80" viewBox="0 0 24 24" fill="currentColor"><path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"/></svg>
              Get it on GitHub
            </a>
          </div>
        </div>

        <!-- Mac App Store — coming soon -->
        <div class="border border-black/[0.08] rounded-[20px] px-8 pt-10 pb-8 flex flex-col items-center">
          <p class="text-xs font-semibold uppercase tracking-widest text-muted">Mac App Store</p>
          <div class="text-[clamp(48px,10vw,72px)] font-black tracking-[-0.04em] leading-none text-text mt-3">
            $4.99
          </div>
          <p class="text-sm text-muted mt-3">One-time purchase. No subscriptions.</p>
          <div class="mt-auto pt-8 w-full flex flex-col items-center gap-3">
            <span class="w-full max-w-[240px] h-12 inline-flex items-center justify-center gap-2 bg-black/[0.06] text-faint rounded-pill text-sm font-semibold cursor-default">
              Coming Soon
            </span>
            <button
              @click="notifyOpen = true"
              class="text-sm text-[#007AFF] hover:text-[#0056b3] underline underline-offset-2 transition-colors duration-150 rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
            >
              Get notified when available
            </button>
          </div>
        </div>
      </div>

      <div class="mt-10 flex flex-wrap justify-center gap-x-5 gap-y-1.5 text-[15px] text-muted">
        {perks.map((perk, i) => (
          <>
            {i > 0 && <span class="text-faint" aria-hidden="true">&middot;</span>}
            <span>{perk}</span>
          </>
        ))}
      </div>
    )}
  </div>

  <!-- Notify modal — rendered at section level for proper fullscreen overlay -->
  <div
    x-cloak
    x-show="notifyOpen"
    x-transition.opacity.duration.150ms
    @click.self="notifyOpen = false"
    @keydown.escape.window="notifyOpen = false"
    x-effect="notifyOpen ? document.body.style.overflow = 'hidden' : document.body.style.overflow = ''"
    role="dialog"
    aria-modal="true"
    aria-label="Get notified when available"
    class="fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-md px-4"
  >
    <div
      x-show="notifyOpen"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 scale-95"
      x-transition:enter-end="opacity-100 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-95"
      x-trap.noscroll="notifyOpen"
      @click.stop
      class="relative bg-surface border border-black/[0.08] rounded-[20px] px-8 py-8 w-full max-w-sm text-center shadow-[0_20px_60px_rgba(0,0,0,0.25)]"
      x-data="notifyForm()"
    >
      <!-- Close button -->
      <button @click="notifyOpen = false" class="absolute top-2 right-2 w-11 h-11 flex items-center justify-center text-faint hover:text-text transition-colors duration-150 rounded-full focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" aria-label="Close">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.9997 10.5865L16.9495 5.63672L18.3637 7.05093L13.4139 12.0007L18.3637 16.9504L16.9495 18.3646L11.9997 13.4149L7.04996 18.3646L5.63574 16.9504L10.5855 12.0007L5.63574 7.05093L7.04996 5.63672L11.9997 10.5865Z"/></svg>
      </button>

      <template x-if="!submitted">
        <div>
          <h3 id="notify-title" class="text-lg font-bold text-text">Get notified</h3>
          <p class="text-sm text-muted mt-2">We'll email you once OpenDictation is on the Mac App Store. No spam.</p>
          <form @submit.prevent="submit()" class="mt-6">
            <label for="notify-email" class="sr-only">Email address</label>
            <input
              id="notify-email"
              type="email"
              x-model="email"
              @input="error = ''"
              required
              autocomplete="email"
              placeholder="you@email.com"
              class="w-full px-4 py-3 rounded-[12px] bg-bg border text-text text-sm placeholder:text-faint focus:outline-none transition-colors duration-150"
              :class="error ? 'border-rec' : 'border-black/[0.08] focus:border-accent/30'"
              :aria-invalid="error ? 'true' : 'false'"
              aria-describedby="notify-error"
            />
            <p x-cloak x-show="error" x-text="error" id="notify-error" role="alert" class="mt-1.5 text-xs text-rec text-left"></p>
            <button
              type="submit"
              :disabled="loading || !email"
              class="mt-3 w-full bg-accent text-white px-8 py-3 rounded-pill text-sm font-semibold hover:bg-accent/85 transition-[background-color,transform] duration-150 active:scale-[0.97] disabled:opacity-50 disabled:active:scale-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
            >
              <span x-show="!loading">Notify me</span>
              <span x-cloak x-show="loading">Sending...</span>
            </button>
          </form>
        </div>
      </template>

      <template x-if="submitted">
        <div class="py-4" role="status">
          <svg class="w-8 h-8 text-ok" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.9997 15.1709L19.1921 5.97852L20.6063 7.39273L9.9997 17.9993L3.63574 11.6354L5.04996 10.2212L9.9997 15.1709Z"/></svg>
          <h3 class="text-lg font-bold text-text mt-3">You're on the list</h3>
          <p class="text-sm text-muted mt-2">We'll let you know when it's ready.</p>
        </div>
      </template>
    </div>
  </div>
</section>

<script is:inline>
  function notifyForm() {
    return {
      email: '',
      error: '',
      loading: false,
      submitted: false,
      async submit() {
        if (this.loading) return
        var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/
        if (!this.email || !emailPattern.test(this.email)) {
          this.error = 'Please enter a valid email address.'
          return
        }
        this.loading = true
        try {
          var formBody = 'email=' + encodeURIComponent(this.email)
          var res = await fetch('https://app.loops.so/api/newsletter-form/cmmd8faob01o60iukfzp6vz6s', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: formBody,
          })
          if (!res.ok) throw new Error('Request failed')
          this.submitted = true
        } catch (e) {
          this.error = 'Something went wrong. Please try again.'
          this.loading = false
        }
      },
    }
  }
</script>
