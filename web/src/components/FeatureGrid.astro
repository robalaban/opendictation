---
const leadFeatures = [
  {
    title: 'Toggle. Speak. Done.',
    description: 'Press once to start, speak naturally, press again to stop. Text appears in realtime, right where your cursor is.',
    chip: '⌥ Space',
  },
  {
    title: 'Realtime transcription.',
    description: 'Words appear as you speak — no waiting, no processing delay. See exactly what will be inserted before it lands.',
  },
]

const supportingFeatures = [
  {
    title: 'Any app, any field',
    description: 'Text goes wherever your cursor is.',
  },
  {
    title: 'Fast & local',
    description: 'Runs on your Mac. Nothing leaves your device.',
  },
  {
    title: 'Menu bar + app',
    description: 'Lives in your menu bar. Full app when you need it.',
    icon: '/opendictation_small.png',
  },
  {
    title: 'Custom hotkey',
    description: 'Remap to any shortcut.',
    chip: '⌘ ⇧ D',
  },
]
---

<section class="pt-32 pb-40 px-6">
  <!-- Lead features — dramatic, full-width -->
  <div class="max-w-3xl mx-auto">
    {leadFeatures.map((feature, i) => (
      <div class="reveal mb-20 last:mb-0" style={`transition-delay: ${i * 100}ms`}>
        <div class="flex items-baseline gap-4 flex-wrap">
          <h3 class="text-[clamp(28px,4.5vw,48px)] font-black tracking-[-0.02em] text-text leading-[1.05]">{feature.title}</h3>
          {feature.chip && (
            <kbd class="inline-flex items-center px-3 py-1 text-sm font-medium text-muted bg-black/[0.04] border border-black/[0.08] rounded-[8px] shadow-[0_2px_0_rgba(0,0,0,0.06),inset_0_1px_0_rgba(255,255,255,0.6)] whitespace-nowrap translate-y-[-2px]">{feature.chip}</kbd>
          )}
        </div>
        <p class="text-lg text-muted mt-3 max-w-lg leading-relaxed">{feature.description}</p>
      </div>
    ))}
  </div>

  <!-- Supporting features — compact, lighter -->
  <div class="max-w-3xl mx-auto mt-24 grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-10">
    {supportingFeatures.map((feature, i) => (
      <div class="reveal" style={`transition-delay: ${(i + 2) * 80}ms`}>
        <div class="flex items-center gap-2">
          <h4 class="text-[15px] font-bold text-text">{feature.title}</h4>
          {feature.icon && (
            <img src={feature.icon} alt="" width="16" height="16" class="opacity-60" />
          )}
          {feature.chip && (
            <kbd class="inline-flex items-center px-1.5 py-px text-[10px] font-medium text-faint bg-black/[0.03] border border-black/[0.06] rounded-[4px] whitespace-nowrap">{feature.chip}</kbd>
          )}
        </div>
        <p class="text-[13px] text-muted mt-1 leading-relaxed">{feature.description}</p>
      </div>
    ))}
  </div>
</section>
